# WSB Brand Site environment variables.
# Copy this file to .env.local and fill in the real values.

# Database (Neon Postgres or Vercel Postgres)
# Get from https://console.neon.tech or `vercel env pull` after linking project
DATABASE_URL="postgres://USER:PASSWORD@HOST/DB?sslmode=require"

# Resend transactional email (https://resend.com)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"

# Sender address (must be on a verified domain in Resend, or use the onboarding sandbox)
RESEND_FROM="noreply@woorismartbio.com"

# Notification recipients for Partnership Inquiry submissions (comma separated)
INQUIRY_NOTIFY_TO="contact@woorismartbio.com"

# Auth (admin) — single-master credentials provider
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=""
ADMIN_EMAIL="admin@woorismartbio.com"
ADMIN_PASSWORD=""

# Public site URL (used to build absolute URLs in emails and OG tags)
NEXT_PUBLIC_SITE_URL="https://woorismartbio.com"

# Vercel Blob (for admin file uploads)
BLOB_READ_WRITE_TOKEN=""

# Analytics (both optional, only load when set)
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_GTM_ID=""
