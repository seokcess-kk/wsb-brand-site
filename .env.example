# WSB Brand Site environment variables.
# Copy this file to .env.local and fill in the real values.

# Database (Supabase Postgres)
# Get from Supabase dashboard → Connect → ORM/postgres tab.
# App runtime: Transaction pooler (port 6543). prepare:false is set in code.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres"
# Migrations only (drizzle-kit): Session pooler or Direct connection (port 5432).
DIRECT_DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# Resend transactional email (https://resend.com)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"

# Sender address (must be on a verified domain in Resend, or use the onboarding sandbox)
RESEND_FROM="noreply@woorismartbio.com"

# Notification recipients for Partnership Inquiry submissions (comma separated)
INQUIRY_NOTIFY_TO="contact@woorismartbio.com"

# Auth (admin) — single-master credentials provider
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=""
ADMIN_EMAIL="admin@woorismartbio.com"
ADMIN_PASSWORD=""

# Public site URL (used to build absolute URLs in emails and OG tags)
NEXT_PUBLIC_SITE_URL="https://woorismartbio.com"

# Vercel Blob (for admin file uploads)
BLOB_READ_WRITE_TOKEN=""

# Analytics (both optional, only load when set)
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_GTM_ID=""

# Naver Maps (NCP) — headquarters map on the Company page.
# Register an app at https://www.ncloud.com (Services > Maps), enable the Dynamic
# Map, and add the Web service URL(s): http://localhost:3000 and your prod domain.
# Without this the map falls back to a Naver "view on map" deep link.
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=""
